{
  "id": "react-native-expo",
  "linter": "eslint",
  "linter_config": "expo",
  "formatter": "prettier",
  "type_checker": "typescript",
  "test_runner": "jest",
  "test_framework": "React Native Testing Library",
  "e2e_runner": "Detox",
  "security_scanner": "npm audit",
  "min_coverage": 80,
  "complexity_threshold": 15,
  "license_policy": ["MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "ISC", "0BSD"],
  "package_manager": "npm",
  "node_version": "20",
  "key_dependencies": [
    "expo", "react-native", "react", "typescript",
    "expo-router", "react-native-safe-area-context"
  ],
  "dev_dependencies": [
    "jest", "@testing-library/react-native",
    "eslint", "prettier", "@types/react"
  ]
}
