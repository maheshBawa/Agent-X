#!/usr/bin/env bash
# Agent-X CLI
# Usage: agent-x <command> [args]
set -euo pipefail

AGENT_X_HOME="$(cd "$(dirname "$0")" && pwd)"
COMMAND="${1:-help}"
PROJECT_DIR="$(pwd)"

case "$COMMAND" in
  init)
    echo "Initializing Agent-X in: $PROJECT_DIR"

    # Create .agent-x directory
    mkdir -p "$PROJECT_DIR/.agent-x"

    # Copy project state template
    cp "$AGENT_X_HOME/templates/project-state.json" "$PROJECT_DIR/.agent-x/project-state.json"

    # Update state with project info (portable: write via temp file, no sed -i)
    TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    PROJECT_NAME=$(basename "$PROJECT_DIR")
    STATE_FILE="$PROJECT_DIR/.agent-x/project-state.json"

    sed \
      -e "s|\"project_name\": \"\"|\"project_name\": \"$PROJECT_NAME\"|" \
      -e "s|\"agent_x_home\": \"\"|\"agent_x_home\": \"$AGENT_X_HOME\"|" \
      -e "s|\"created_at\": \"\"|\"created_at\": \"$TIMESTAMP\"|" \
      -e "s|\"updated_at\": \"\"|\"updated_at\": \"$TIMESTAMP\"|" \
      "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"

    # Copy CLAUDE.md template (back up existing if present)
    if [ -f "$PROJECT_DIR/CLAUDE.md" ]; then
      cp "$PROJECT_DIR/CLAUDE.md" "$PROJECT_DIR/CLAUDE.md.backup"
      echo "  Existing CLAUDE.md backed up to CLAUDE.md.backup"
    fi
    sed "s|{{AGENT_X_HOME}}|$AGENT_X_HOME|g" "$AGENT_X_HOME/templates/project-claude.md" > "$PROJECT_DIR/CLAUDE.md"

    # Copy AGENTS.md template (back up existing if present)
    if [ -f "$PROJECT_DIR/AGENTS.md" ]; then
      cp "$PROJECT_DIR/AGENTS.md" "$PROJECT_DIR/AGENTS.md.backup"
      echo "  Existing AGENTS.md backed up to AGENTS.md.backup"
    fi
    sed "s|{{AGENT_X_HOME}}|$AGENT_X_HOME|g" "$AGENT_X_HOME/templates/project-agents.md" > "$PROJECT_DIR/AGENTS.md"

    # Copy hooks
    mkdir -p "$PROJECT_DIR/.claude/hooks"
    cp "$AGENT_X_HOME/.claude/hooks/"*.sh "$PROJECT_DIR/.claude/hooks/" 2>/dev/null || true
    chmod +x "$PROJECT_DIR/.claude/hooks/"*.sh 2>/dev/null || true

    # Copy settings
    cp "$AGENT_X_HOME/.claude/settings.json" "$PROJECT_DIR/.claude/settings.json"

    # Initialize git if needed
    if [ ! -d "$PROJECT_DIR/.git" ]; then
      cd "$PROJECT_DIR" && git init
    fi

    # Create .gitignore if it doesn't exist
    if [ ! -f "$PROJECT_DIR/.gitignore" ]; then
      cat > "$PROJECT_DIR/.gitignore" << 'GITIGNORE'
# Environment
.env
.env.local
.env.*.local

# Dependencies
node_modules/
venv/
__pycache__/

# Build
.next/
dist/
build/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Agent-X sensitive files
.agent-x/security-exceptions.md
GITIGNORE
    fi

    echo ""
    echo "============================================"
    echo "  Agent-X initialized: $PROJECT_NAME"
    echo "============================================"
    echo ""
    echo "Run 'claude' to start. Agent-X will take over."
    ;;

  update)
    # Update hooks, settings, and templates from Agent-X home — preserves project state and user files
    if [ ! -d "$PROJECT_DIR/.agent-x" ]; then
      echo "No Agent-X project found. Run 'agent-x init' first."
      exit 1
    fi

    CURRENT_VERSION=$(cat "$AGENT_X_HOME/VERSION" 2>/dev/null || echo "unknown")
    echo "Updating project to Agent-X v$CURRENT_VERSION..."

    # Update hooks
    mkdir -p "$PROJECT_DIR/.claude/hooks"
    cp "$AGENT_X_HOME/.claude/hooks/"*.sh "$PROJECT_DIR/.claude/hooks/" 2>/dev/null || true
    chmod +x "$PROJECT_DIR/.claude/hooks/"*.sh 2>/dev/null || true
    echo "  ✓ Hooks updated"

    # Update settings.json
    cp "$AGENT_X_HOME/.claude/settings.json" "$PROJECT_DIR/.claude/settings.json"
    echo "  ✓ Settings updated"

    # Update CLAUDE.md (back up existing)
    if [ -f "$PROJECT_DIR/CLAUDE.md" ]; then
      cp "$PROJECT_DIR/CLAUDE.md" "$PROJECT_DIR/CLAUDE.md.backup"
    fi
    sed "s|{{AGENT_X_HOME}}|$AGENT_X_HOME|g" "$AGENT_X_HOME/templates/project-claude.md" > "$PROJECT_DIR/CLAUDE.md"
    echo "  ✓ CLAUDE.md updated (previous backed up to CLAUDE.md.backup)"

    # Update AGENTS.md (back up existing)
    if [ -f "$PROJECT_DIR/AGENTS.md" ]; then
      cp "$PROJECT_DIR/AGENTS.md" "$PROJECT_DIR/AGENTS.md.backup"
    fi
    sed "s|{{AGENT_X_HOME}}|$AGENT_X_HOME|g" "$AGENT_X_HOME/templates/project-agents.md" > "$PROJECT_DIR/AGENTS.md"
    echo "  ✓ AGENTS.md updated (previous backed up to AGENTS.md.backup)"

    # Update agent_x_home in project state (in case Agent-X moved)
    STATE_FILE="$PROJECT_DIR/.agent-x/project-state.json"
    if [ -f "$STATE_FILE" ]; then
      TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
      sed \
        -e "s|\"agent_x_home\": \"[^\"]*\"|\"agent_x_home\": \"$AGENT_X_HOME\"|" \
        -e "s|\"updated_at\": \"[^\"]*\"|\"updated_at\": \"$TIMESTAMP\"|" \
        "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"
    fi

    echo ""
    echo "============================================"
    echo "  Agent-X updated to v$CURRENT_VERSION"
    echo "============================================"
    echo ""
    echo "Project state, build progress, and .agent-x/ docs preserved."
    ;;

  reset)
    STATE_FILE="$PROJECT_DIR/.agent-x/project-state.json"
    TARGET_PHASE="${2:-INTAKE}"
    if [ ! -f "$STATE_FILE" ]; then
      echo "No Agent-X project found. Run 'agent-x init' first."
      exit 1
    fi
    # Validate phase
    case "$TARGET_PHASE" in
      INTAKE|TECH_STACK|ARCHITECTURE|BUILD|VERIFY|DEPLOY) ;;
      *) echo "Invalid phase: $TARGET_PHASE"; echo "Valid phases: INTAKE, TECH_STACK, ARCHITECTURE, BUILD, VERIFY, DEPLOY"; exit 1 ;;
    esac
    # Update state file
    sed \
      -e "s|\"current_phase\": \"[^\"]*\"|\"current_phase\": \"$TARGET_PHASE\"|" \
      -e "s|\"phase_status\": \"[^\"]*\"|\"phase_status\": \"not_started\"|" \
      "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"
    echo "Agent-X reset to phase: $TARGET_PHASE"
    echo "Run 'claude' to continue from this phase."
    ;;

  status)
    STATE_FILE="$PROJECT_DIR/.agent-x/project-state.json"
    if [ -f "$STATE_FILE" ]; then
      echo "Agent-X Project Status:"
      cat "$STATE_FILE"
    else
      echo "No Agent-X project found in current directory."
      echo "Run 'agent-x init' to initialize."
    fi
    ;;

  version)
    VERSION=$(cat "$AGENT_X_HOME/VERSION" 2>/dev/null || echo "unknown")
    echo "Agent-X v$VERSION"
    ;;

  help|*)
    echo "Agent-X — Autonomous AI Development Environment"
    echo ""
    echo "Usage: agent-x <command>"
    echo ""
    echo "Commands:"
    echo "  init              Initialize Agent-X in the current directory"
    echo "  update            Update hooks, settings, and templates from Agent-X repo"
    echo "  status            Show project status"
    echo "  reset [PHASE]     Reset project to a specific phase (default: INTAKE)"
    echo "  version           Show Agent-X version"
    echo "  help              Show this help message"
    echo ""
    echo "After init, run 'claude' to start building."
    ;;
esac
